# .env.local.example
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored by Next.js default.

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# (Optional) Custom LLM API base URL — leave blank to use the official OpenAI API.
# Use this to point at a proxy, Azure OpenAI, or any OpenAI-compatible endpoint.
# Example (local proxy): OPENAI_API_BASE_URL=http://localhost:8080/v1
# Example (Azure):       OPENAI_API_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
OPENAI_API_BASE_URL=

# (Optional) LLM model name — defaults to gpt-4o-mini when unset.
# Set this to use a different model, e.g. gpt-4o, gpt-4-turbo, or a compatible model ID.
OPENAI_MODEL=

# PostgreSQL connection string — local Postgres running on localhost
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://postgres:postgres@localhost:5432/chatbot
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE
